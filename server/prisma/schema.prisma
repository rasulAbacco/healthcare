generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  fullName          String
  email             String             @unique
  phone             String             @unique
  password          String
  role              Role
  modules           Module[]           @default([])
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  notificationReads NotificationRead[]
}

model IPD_Patient {
  id               String            @id @default(cuid())
  serialNumber     String            @unique
  name             String
  age              Int
  gender           String
  phone            String?
  aadhar           String?
  admissionDate    DateTime
  admissionTime    String
  expectedDays     Int?
  dischargeDate    DateTime?
  dischargeTime    String?
  status           String            @default("Admitted")
  dischargeStatus  String            @default("Admitted")
  notes            String?
  deposit          Float             @default(0)
  cash             Float             @default(0)
  upi              Float             @default(0)
  card             Float             @default(0)
  totalPaid        Float             @default(0)
  totalStay        Float             @default(0)
  balance          Float             @default(0)
  settlementStatus String            @default("Pending")
  oil              Int               @default(0)
  protein          Int               @default(0)
  syrup            Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  dailyCharges     IPD_DailyCharge[]
  documents        IPD_Document[]
  medicines        IPD_Medicine[]
  payments         IPD_Payment[]

  @@map("ipd_patients")
}

model IPD_DailyCharge {
  id        String      @id @default(cuid())
  date      DateTime
  days      Float
  rate      Float
  amount    Float
  patientId String
  createdAt DateTime    @default(now())
  patient   IPD_Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("ipd_daily_charges")
}

model IPD_Medicine {
  id           String      @id @default(cuid())
  name         String
  quantity     Float
  unit         String      @default("Tablets")
  medicineId   String?
  dosage       String?
  frequency    String?
  duration     String?
  instructions String?
  patientId    String
  createdAt    DateTime    @default(now())
  medicine     Medicine?   @relation(fields: [medicineId], references: [id])
  patient      IPD_Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("ipd_medicines")
}

model IPD_Payment {
  id              String        @id @default(cuid())
  amount          Float
  method          PaymentMethod
  referenceNumber String?
  notes           String?
  paymentDate     DateTime      @default(now())
  patientId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  patient         IPD_Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("ipd_payments")
}

model IPD_Document {
  id        String      @id @default(cuid())
  name      String
  type      String
  url       String
  fileType  String?
  patientId String
  createdAt DateTime    @default(now())
  patient   IPD_Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("ipd_documents")
}

model OPDPatient {
  id                  String               @id @default(cuid())
  tokenNumber         Int                  @unique @default(autoincrement())
  name                String
  age                 Int
  gender              Gender
  place               String?
  phone               String?
  fee                 Float
  cash                Float                @default(0)
  upi                 Float                @default(0)
  total               Float                @default(0)
  visitDate           DateTime             @db.Date
  notes               String?
  followUpDate        DateTime?            @db.Date
  condition           PatientCondition?
  followUpDesc        String?
  followUpStatus      FollowUpStatus       @default(PENDING)
  reminderEnabled     Boolean              @default(false)
  reminderStatus      ReminderStatus       @default(NOT_SET)
  reminderSentDate    DateTime?            @db.Date
  diagnosis           String?
  prescription        String?
  doctorNotes         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  prescribedMedicines PrescribedMedicine[]
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  medicines Medicine[]
}

model Medicine {
  id                  String               @id @default(cuid())
  serialNumber        String               @unique
  drugName            String
  genericName         String?
  categoryId          String
  manufacturer        String?
  batchNumber         String
  purchasePrice       Float
  sellingPrice        Float
  quantity            Int                  @default(0)
  reorderLevel        Int                  @default(0)
  expiryDate          DateTime             @db.Date
  supplierName        String?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  category            Category             @relation(fields: [categoryId], references: [id])
  prescribedMedicines PrescribedMedicine[]
  stockHistory        StockHistory[]
  ipdMedicines        IPD_Medicine[]
}

model StockHistory {
  id         String      @id @default(cuid())
  medicineId String
  date       DateTime    @db.Date
  action     StockAction
  quantity   Int
  reason     String
  createdAt  DateTime    @default(now())
  medicine   Medicine    @relation(fields: [medicineId], references: [id], onDelete: Cascade)
}

model PrescribedMedicine {
  id                 String     @id @default(cuid())
  opdPatientId       String
  medicineId         String
  quantity           Int
  dosageInstructions String?
  createdAt          DateTime   @default(now())
  medicine           Medicine   @relation(fields: [medicineId], references: [id])
  opdPatient         OPDPatient @relation(fields: [opdPatientId], references: [id], onDelete: Cascade)
}

model NotificationRead {
  id     String   @id @default(cuid())
  userId String
  key    String
  readAt DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model LoginOtp {
  id         String   @id @default(cuid())
  identifier String
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Otp {
  id         String   @id @default(cuid())
  identifier String
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

enum Role {
  DOCTOR
  RECEPTIONIST
  PHARMACY
}

enum Module {
  OPD
  IPD
  PHARMACY
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientCondition {
  STABLE
  IMPROVING
  CHRONIC
  MILD
  GOOD
  CRITICAL
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
}

enum ReminderStatus {
  NOT_SET
  PENDING
  SENT
  FAILED
}

enum StockAction {
  ADD
  REDUCE
  ADJUST
}
