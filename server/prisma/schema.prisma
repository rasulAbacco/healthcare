generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  RECEPTIONIST
  PHARMACY
}

enum Module {
  OPD
  IPD
  PHARMACY
}

model User {
  id       String   @id @default(cuid())
  fullName String
  email    String   @unique
  phone    String?  @unique
  password String
  role     Role
  modules  Module[] @default([])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientCondition {
  STABLE
  IMPROVING
  CHRONIC
  MILD
  GOOD
  CRITICAL
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
}

enum ReminderStatus {
  NOT_SET
  PENDING
  SENT
  FAILED
}

model OPDPatient {
  id          String @id @default(cuid())
  tokenNumber Int    @unique @default(autoincrement())
  // Display serial like "OPD-001" is built from tokenNumber in the API layer —
  // not stored, so there's nothing to keep in sync.

  name   String
  age    Int
  gender Gender
  place  String?
  phone  String?

  fee   Float
  cash  Float @default(0)
  upi   Float @default(0)
  total Float @default(0) // = cash + upi, computed and stored at write time

  visitDate DateTime @db.Date
  notes     String?  @db.Text

  followUpDate   DateTime?         @db.Date
  condition      PatientCondition?
  followUpDesc   String?           @db.Text
  followUpStatus FollowUpStatus    @default(PENDING)

  reminderEnabled  Boolean        @default(false)
  reminderStatus   ReminderStatus @default(NOT_SET)
  reminderSentDate DateTime?      @db.Date

  // Filled in later by the doctor dashboard, not the registration form
  diagnosis    String? @db.Text
  prescription String? @db.Text
  doctorNotes  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  medicines Medicine[]
}

model Medicine {
  id            String   @id @default(cuid())
  serialNumber  String   @unique // manually typed by pharmacist, e.g. "MED-001"
  drugName      String
  genericName   String?
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  manufacturer  String?
  batchNumber   String
  purchasePrice Float
  sellingPrice  Float
  quantity      Int      @default(0)
  reorderLevel  Int      @default(0)
  expiryDate    DateTime @db.Date
  supplierName  String?
  notes         String?  @db.Text

  stockHistory StockHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StockAction {
  ADD
  REDUCE
  ADJUST
}

model StockHistory {
  id         String      @id @default(cuid())
  medicineId String
  medicine   Medicine    @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  date       DateTime    @db.Date
  action     StockAction
  quantity   Int // positive for Add, negative for Reduce — matches current UI convention
  reason     String

  createdAt DateTime @default(now())
}
