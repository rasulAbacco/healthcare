generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Pure information — NOT a login account. Admin maintains this as a staff
// directory (nurses, ward boys, cleaners, etc.) — no password, no Role, no
// auth involvement at all. Kept entirely separate from User on purpose.
model Employee {
  id           String   @id @default(cuid())
  fullName     String
  designation  String   // free text: "Nurse", "Ward Boy", "Cleaner", etc. — not an enum, so new job titles don't need a migration
  phone        String?
  email        String?
  joiningDate  DateTime @db.Date
  isActive     Boolean  @default(true)
  notes        String?

  // Salary/bank details — entirely optional. Directory records can exist
  // with none of this filled in; nothing here is required to create or
  // update an employee.
  salary        Float?
  bankName      String?
  ifscCode      String?
  bankAccountNo String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id                String             @id @default(cuid())
  fullName          String
  email             String             @unique
  phone             String             @unique
  password          String
  role              Role
  modules           Module[]           @default([])
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  notificationReads NotificationRead[]
}

model IPD_Patient {
  id               String   @id @default(cuid())
  serialNumber     String   @unique
  name             String
  age              Int
  gender           String
  phone            String?
  aadhar           String?

  admissionDate    DateTime
  admissionTime    String
  expectedDays     Int?

  dischargeDate    DateTime?
  dischargeTime    String?
  status           String   @default("Admitted")
  dischargeStatus  String   @default("Admitted")
  notes            String?

  followUpDate     DateTime?
  condition        PatientCondition?
  followUpDesc     String?
  followUpStatus   FollowUpStatus @default(PENDING)
  reminderEnabled  Boolean @default(false)
  reminderStatus   ReminderStatus @default(NOT_SET)
  reminderSentDate DateTime?

  deposit          Float @default(0)
  cash             Float @default(0)
  upi              Float @default(0)
  card             Float @default(0)
  totalPaid        Float @default(0)
  totalStay        Float @default(0)
  balance          Float @default(0)
  settlementStatus String @default("Pending")

  oil              Int @default(0)
  protein          Int @default(0)
  syrup            Int @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dailyCharges     IPD_DailyCharge[]
  documents        IPD_Document[]
  medicines        IPD_Medicine[]
  payments         IPD_Payment[]

  @@map("ipd_patients")
}

model IPD_DailyCharge {
  id        String      @id @default(cuid())
  date      DateTime
  days      Float
  rate      Float
  amount    Float
  patientId String
  createdAt DateTime    @default(now())
  patient   IPD_Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("ipd_daily_charges")
}

model IPD_Medicine {
  id           String      @id @default(cuid())
  name         String
  quantity     Float
  unit         String      @default("Tablets")
  medicineId   String?
  dosage       String?
  frequency    String?
  duration     String?
  instructions String?
  patientId    String
  createdAt    DateTime    @default(now())
  medicine     medicine?   @relation(fields: [medicineId], references: [id])
  patient      IPD_Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("ipd_medicines")
}

model IPD_Payment {
  id              String        @id @default(cuid())
  amount          Float
  method          PaymentMethod
  referenceNumber String?
  notes           String?
  paymentDate     DateTime      @default(now())
  patientId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  patient         IPD_Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("ipd_payments")
}

model IPD_Document {
  id        String      @id @default(cuid())
  name      String
  type      String
  url       String
  fileType  String?
  patientId String
  createdAt DateTime    @default(now())
  patient   IPD_Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("ipd_documents")
}

model OPDPatient {
  id                  String               @id @default(cuid())
  tokenNumber         Int                  @unique @default(autoincrement())
  name                String
  age                 Int
  gender              Gender
  place               String?
  phone               String?
  fee                 Float                @default(0)
  cash                Float                @default(0)
  upi                 Float                @default(0)
  total               Float                @default(0)
  visitDate           DateTime             @db.Date
  notes               String?
  followUpDate        DateTime?            @db.Date
  condition           PatientCondition?
  followUpDesc        String?
  followUpStatus      FollowUpStatus       @default(PENDING)
  reminderEnabled     Boolean              @default(false)
  reminderStatus      ReminderStatus       @default(NOT_SET)
  reminderSentDate    DateTime?            @db.Date
  diagnosis           String?
  prescription        String?
  doctorNotes         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  prescribedMedicines PrescribedMedicine[]
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  medicines medicine[]
}

model medicine {
  id                  String               @id @default(cuid())
  serialNumber        String               @unique
  drugName            String
  genericName         String?
  categoryId          String
  manufacturer        String?
  batchNumber         String
  purchasePrice       Float
  sellingPrice        Float
  // How many individual tablets/units are in one pack/strip/box.
  // purchasePrice/sellingPrice are per PACK; quantity (below) is tracked in
  // individual UNITS (matches how OPD prescriptions and stock actions already
  // subtract/add). Per-unit price = purchasePrice/sellingPrice ÷ unitsPerPack.
  // Defaults to 1 so existing rows (and any medicine where price already IS
  // per-unit) keep working with no data migration required.
  unitsPerPack        Int                  @default(1)
  quantity            Int                  @default(0)
  initialQuantity     Int                  @default(0)
  reorderLevel        Int                  @default(0)
  expiryDate          DateTime             @db.Date
  supplierName        String?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  category            Category             @relation(fields: [categoryId], references: [id])
  prescribedMedicines PrescribedMedicine[]
  stockHistory        StockHistory[]
  ipdMedicines        IPD_Medicine[]
}

model StockHistory {
  id         String      @id @default(cuid())
  medicineId String
  date       DateTime    @db.Date
  action     StockAction
  quantity   Int
  reason     String
  createdAt  DateTime    @default(now())
  medicine   medicine    @relation(fields: [medicineId], references: [id], onDelete: Cascade)
}

model PrescribedMedicine {
  id                 String     @id @default(cuid())
  opdPatientId       String
  medicineId         String
  quantity           Int
  dosageInstructions String?
  createdAt          DateTime   @default(now())
  medicine           medicine   @relation(fields: [medicineId], references: [id])
  opdPatient         OPDPatient @relation(fields: [opdPatientId], references: [id], onDelete: Cascade)
}

model NotificationRead {
  id     String   @id @default(cuid())
  userId String
  key    String
  readAt DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model LoginOtp {
  id         String   @id @default(cuid())
  identifier String
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Otp {
  id         String   @id @default(cuid())
  identifier String
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PHARMACY
}

enum Module {
  OPD
  IPD
  PHARMACY
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientCondition {
  STABLE
  IMPROVING
  CHRONIC
  MILD
  GOOD
  CRITICAL
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
}

enum ReminderStatus {
  NOT_SET
  PENDING
  SENT
  FAILED
}

enum StockAction {
  ADD
  REDUCE
  ADJUST
}


// BIOMETRIC ATTENDANCE MODULES

model BiometricDevice {
  id           String   @id @default(cuid())
  name         String
  deviceCode   String   @unique
  serialNumber String   @unique
  location     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mappings     BiometricMapping[]
  logs         BiometricLog[]
  attendances  Attendance[]

  @@map("biometric_devices")
}


model BiometricMapping {
  id          String   @id @default(cuid())
  biometricId String   @unique // globally unique across all devices, per your instruction
  deviceId    String
  userId      String?  // plain scalar — see note above, not a Prisma relation
  employeeId  String?  // plain scalar — see note above, not a Prisma relation
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  device      BiometricDevice @relation(fields: [deviceId], references: [id])
  attendances Attendance[]

  @@map("biometric_mappings")
}

model BiometricLog {
  id            String    @id @default(cuid())
  deviceId      String
  deviceSerial  String
  enrollmentId  String
  punchTime     DateTime
  punchMode     PunchMode @default(UNKNOWN)
  rawData       Json
  isProcessed   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  device        BiometricDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId, enrollmentId, punchTime])
  @@map("biometric_logs")
}

model Attendance {
  id               String           @id @default(cuid())
  userId           String?          // plain scalar — see note above, not a Prisma relation
  employeeId       String?          // plain scalar — see note above, not a Prisma relation
  mappingId        String?
  deviceId         String?
  date             DateTime         @db.Date
  firstPunch       DateTime?
  lastPunch        DateTime?
  workingMinutes   Int              @default(0)
  lateMinutes      Int              @default(0)
  overtimeMinutes  Int              @default(0)
  status           AttendanceStatus @default(ABSENT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  mapping          BiometricMapping? @relation(fields: [mappingId], references: [id])
  device           BiometricDevice?  @relation(fields: [deviceId], references: [id])

  @@unique([userId, employeeId, date])
  @@map("attendances")
}

enum PunchMode {
  IN
  OUT
  UNKNOWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
}
